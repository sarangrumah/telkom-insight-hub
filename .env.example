# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# Local development
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/telkom_hub
# Docker (set by docker-compose.yml automatically)
# DATABASE_URL=postgresql://panel_user:panel_password@db:5432/panel_hub
DATABASE_SSL=false
DEBUG_SQL=true

# ── Authentication (JWT) ──────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_TO_A_SECURE_SECRET_AT_LEAST_32_CHARS"
ACCESS_EXPIRES_IN=1h
REFRESH_EXPIRES_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,https://e-telekomunikasi.komdigi.go.id

# ── e-Telekomunikasi Integration ──────────────────────────────────────────────
# Internal API URL (Docker: http://web:3000, Local: http://localhost:3000)
ETELEKOM_API_URL=http://localhost:3000
# Service-to-service API key (must match PANEL_SERVICE_API_KEY in e-telekomunikasi .env)
ETELEKOM_SERVICE_KEY=CHANGE_ME_TO_MATCH_ETELEKOMUNIKASI_PANEL_SERVICE_API_KEY

# ── KOMINFO Tarif API ─────────────────────────────────────────────────────────
KOMINFO_TARIF_API_KEY=
KOMINFO_TARIF_API_BASE_URL=https://tariftel.komdigi.go.id/api/v1/api
KOMINFO_TARIF_DEFAULT_TAHUN=2024
KOMINFO_TARIF_DEFAULT_PERIODE=bulanan
KOMINFO_SYNC_ENABLED=false

# ── BPS API ───────────────────────────────────────────────────────────────────
BPS_API_KEY=
# Get your key at https://webapi.bps.go.id/developer/

# ── External API Test ─────────────────────────────────────────────────────────
API_TEST_ALLOWED_HOSTS=httpbin.org,api.github.com,tariftel.komdigi.go.id

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
VITE_MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token_here
